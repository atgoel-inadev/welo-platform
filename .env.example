# ── Host Port Mappings ─────────────────────────────────────────────
# These are the ports exposed on your machine (host:container)
# Change these if the defaults conflict with other services on your machine
POSTGRES_HOST_PORT=6432
REDIS_HOST_PORT=7379
KAFKA_HOST_PORT=10092
KAFKA_CONTROLLER_HOST_PORT=10093
WORKFLOW_ENGINE_HOST_PORT=4001
AUTH_SERVICE_HOST_PORT=4002
TASK_MANAGEMENT_HOST_PORT=4003
PROJECT_MANAGEMENT_HOST_PORT=4004
ANNOTATION_QA_HOST_PORT=4005
NGINX_HOST_PORT=8080
UI_HOST_PORT=5173

# ── UI Build Args (baked into the JS bundle at build time) ────────
# These point to the nginx gateway which routes to backend services
# Change localhost:8080 if you changed NGINX_HOST_PORT above
VITE_AUTH_SERVICE_URL=http://localhost:8080/auth/api/v1
VITE_TASK_MANAGEMENT_URL=http://localhost:8080/tasks/api/v1
VITE_PROJECT_MANAGEMENT_URL=http://localhost:8080/projects/api/v1
VITE_WORKFLOW_ENGINE_URL=http://localhost:8080/workflows/api/v1
VITE_ANNOTATION_QA_URL=http://localhost:8080/annotation-qa/api/v1
VITE_API_URL=http://localhost:8080/projects/api/v1

# ── Messaging Configuration ───────────────────────────────────────
# Messaging provider: 'kafka' (local/docker) or 'aws' (production)
MESSAGING_PROVIDER=kafka

# Kafka Configuration (used when MESSAGING_PROVIDER=kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=welo-platform
KAFKA_CONSUMER_GROUP_ID=welo-platform-group

# AWS SNS/SQS Configuration (used when MESSAGING_PROVIDER=aws)
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
# AWS_TOPIC_PREFIX=welo-platform
# AWS_QUEUE_PREFIX=welo-platform
# AWS_ENABLE_FIFO=false
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
