// Welo Data Annotation Platform - Database Schema
// Generated for dbdiagram.io — paste at https://dbdiagram.io/d
// All tables extend BaseEntity: id (uuid PK), created_at, updated_at, metadata (jsonb)
//
// Performance indexes (see libs/common/src/database/migrations/001_performance_indexes.sql):
//   tasks                 — idx_tasks_claim (partial, WHERE status='QUEUED'), idx_tasks_machine_state_gin (GIN), idx_tasks_annotation_responses_gin (GIN)
//   assignments           — idx_assignments_task_user_status, idx_assignments_expiry (partial), idx_assignments_task_stage_status
//   annotations           — idx_annotations_data_gin (GIN), idx_annotations_task_is_final
//   annotation_responses  — idx_annotation_responses_task_question
//   review_approvals      — idx_review_approvals_task_level_status
//   state_transitions     — idx_state_transitions_entity_time, idx_state_transitions_workflow_time
//   quality_checks        — idx_quality_checks_task_type_status
//   notifications         — idx_notifications_user_unread (partial, WHERE is_read=false)
//   audit_logs            — idx_audit_logs_entity_time
//   plugin_execution_logs — idx_plugin_logs_project_time
//
// Connection pools: DB_POOL_SIZE env var per service (default: task-mgmt=20, project-mgmt=20, others=10-15)
// Redis task queues: task_queue:{projectId}:{taskType} sorted set (score = (10-priority)*1e10 + unix_ts)
// Assignment locks:  assignment_lock:{taskId} SET NX PX 30000

// ─── CUSTOMERS ───────────────────────────────────────────────────────────────

Table customers {
  id            uuid        [pk, default: `gen_random_uuid()`]
  name          varchar(255) [not null]
  email         varchar(255) [unique, not null]
  subscription  varchar(50)  [note: 'free | pro | enterprise']
  status        varchar(20)  [not null, note: 'ACTIVE | INACTIVE | SUSPENDED']
  created_at    timestamp    [not null, default: `now()`]
  updated_at    timestamp    [not null, default: `now()`]
  metadata      jsonb
}

// ─── USERS ───────────────────────────────────────────────────────────────────

Table users {
  id                  uuid         [pk, default: `gen_random_uuid()`]
  email               varchar(255) [unique, not null]
  username            varchar(100) [unique, not null]
  first_name          varchar(100) [not null]
  last_name           varchar(100) [not null]
  role                varchar(30)  [not null, note: 'ANNOTATOR | REVIEWER | QA | PROJECT_MANAGER | ADMIN | CUSTOMER']
  status              varchar(20)  [not null, note: 'ACTIVE | INACTIVE | SUSPENDED']
  skills              jsonb        [note: 'Array<{skillName, proficiency, certifiedAt}>']
  performance_metrics jsonb        [note: '{tasksCompleted, averageQuality, averageSpeed, accuracyRate}']
  availability        jsonb        [note: '{timezone, workingHours, capacity}']
  last_login_at       timestamp
  created_at          timestamp    [not null, default: `now()`]
  updated_at          timestamp    [not null, default: `now()`]
  metadata            jsonb

  indexes {
    email [unique]
    username [unique]
    role
    status
  }
}

// ─── PROJECTS ────────────────────────────────────────────────────────────────

Table projects {
  id                   uuid         [pk, default: `gen_random_uuid()`]
  name                 varchar(255) [not null]
  customer_id          uuid         [not null, ref: > customers.id]
  description          text
  project_type         varchar(20)  [not null, note: 'TEXT | IMAGE | VIDEO | AUDIO | MULTIMODAL']
  status               varchar(20)  [not null, note: 'DRAFT | ACTIVE | PAUSED | COMPLETED | ARCHIVED']
  default_workflow_id  uuid         [ref: > workflows.id]
  configuration        jsonb        [note: '{annotationQuestions[], workflowConfiguration, supportedFileTypes[], plugins[], qualityThresholds, uiConfiguration}']
  created_by           uuid         [ref: > users.id]
  start_date           date
  end_date             date
  created_at           timestamp    [not null, default: `now()`]
  updated_at           timestamp    [not null, default: `now()`]
  metadata             jsonb

  indexes {
    customer_id
    status
    created_at
  }
}

// ─── PROJECT TEAM MEMBERS ─────────────────────────────────────────────────────

Table project_team_members {
  id          uuid        [pk, default: `gen_random_uuid()`]
  project_id  uuid        [not null, ref: > projects.id]
  user_id     uuid        [not null, ref: > users.id]
  role        varchar(50) [not null]
  quota       integer     [note: 'max tasks per day']
  is_active   boolean     [not null, default: true]
  assigned_at timestamp   [not null]
  created_at  timestamp   [not null, default: `now()`]
  updated_at  timestamp   [not null, default: `now()`]
  metadata    jsonb

  indexes {
    project_id
    user_id
    (project_id, user_id)
  }
}

// ─── BATCHES ─────────────────────────────────────────────────────────────────

Table batches {
  id               uuid          [pk, default: `gen_random_uuid()`]
  project_id       uuid          [not null, ref: > projects.id]
  name             varchar(255)  [not null]
  description      text
  status           varchar(20)   [not null, note: 'CREATED | IN_PROGRESS | REVIEW | COMPLETED | EXPORTED']
  priority         integer       [not null, default: 5, note: '1-10']
  total_tasks      integer       [not null, default: 0]
  completed_tasks  integer       [not null, default: 0]
  quality_score    decimal(5,2)
  configuration    jsonb         [note: '{assignmentRules, validationRules, exportSettings}']
  due_date         timestamp
  completed_at     timestamp
  created_at       timestamp     [not null, default: `now()`]
  updated_at       timestamp     [not null, default: `now()`]
  metadata         jsonb

  indexes {
    project_id
    status
    priority
    due_date
  }
}

// ─── TASKS ───────────────────────────────────────────────────────────────────

Table tasks {
  id                          uuid         [pk, default: `gen_random_uuid()`]
  batch_id                    uuid         [not null, ref: > batches.id]
  project_id                  uuid         [not null, ref: > projects.id]
  workflow_id                 uuid         [ref: > workflows.id]
  external_id                 varchar(255) [not null]
  task_type                   varchar(20)  [not null, note: 'ANNOTATION | REVIEW | VALIDATION | CONSENSUS']
  status                      varchar(20)  [not null, note: 'QUEUED | ASSIGNED | IN_PROGRESS | IN_REVIEW | SUBMITTED | APPROVED | REJECTED | SKIPPED']
  priority                    integer      [not null, default: 5, note: '1-10']

  // XState machine state
  machine_state               jsonb        [note: '{value, context, history, done, changed, tags[]}']
  previous_state              jsonb
  state_updated_at            timestamp

  // Task data
  data_payload                jsonb        [not null, note: '{sourceData, references[], context}']

  // File info
  file_type                   varchar(50)  [note: 'CSV | TXT | IMAGE | VIDEO | AUDIO | PDF']
  file_url                    text
  file_metadata               jsonb        [note: '{fileName, fileSize, mimeType, dimensions, duration}']

  // Assignment tracking
  assignment_id               uuid
  attempt_count               integer      [not null, default: 0]
  assigned_at                 timestamp
  started_at                  timestamp
  submitted_at                timestamp
  due_date                    timestamp
  estimated_duration          integer      [note: 'seconds']
  actual_duration             integer      [note: 'seconds']

  // Consensus tracking
  requires_consensus          boolean      [not null, default: false]
  consensus_reached           boolean      [not null, default: false]
  consensus_score             decimal(5,2)
  total_assignments_required  integer      [not null, default: 1]
  completed_assignments       integer      [not null, default: 0]

  // Multi-level review tracking
  current_review_level        integer      [not null, default: 0]
  max_review_level            integer      [not null, default: 0]
  all_reviews_approved        boolean      [not null, default: false]

  // Denormalized fast-access data
  annotation_responses        jsonb        [note: 'Array<{questionId, response, timestamp, annotatorId}>']
  extra_widget_data           jsonb
  review_data                 jsonb        [note: 'Array<{reviewLevel, reviewerId, decision, qualityScore, comments, timestamp}>']

  created_at                  timestamp    [not null, default: `now()`]
  updated_at                  timestamp    [not null, default: `now()`]
  metadata                    jsonb

  indexes {
    batch_id
    project_id
    workflow_id
    status
    priority
    assigned_at
    due_date
    state_updated_at
    (project_id, status, priority)
    // Scalability indexes (001_performance_indexes.sql)
    (project_id, priority, created_at) [name: 'idx_tasks_claim', note: 'partial WHERE status=QUEUED — task claim hot path']
    machine_state [type: gin, name: 'idx_tasks_machine_state_gin']
    annotation_responses [type: gin, name: 'idx_tasks_annotation_responses_gin']
  }
}

// ─── ASSIGNMENTS ─────────────────────────────────────────────────────────────

Table assignments {
  id                uuid        [pk, default: `gen_random_uuid()`]
  task_id           uuid        [not null, ref: > tasks.id]
  user_id           uuid        [not null, ref: > users.id]
  workflow_stage    varchar(20) [not null, note: 'ANNOTATION | REVIEW | VALIDATION | CONSENSUS']
  status            varchar(20) [not null, note: 'ASSIGNED | ACCEPTED | IN_PROGRESS | COMPLETED | EXPIRED | REASSIGNED']
  assigned_at       timestamp   [not null]
  accepted_at       timestamp
  completed_at      timestamp
  expires_at        timestamp
  assignment_method varchar(20) [not null, note: 'AUTOMATIC | MANUAL | CLAIMED']

  // Stage-based workflow
  stage_id          varchar(255)
  rework_count      integer     [not null, default: 0]
  max_rework        integer

  created_at        timestamp   [not null, default: `now()`]
  updated_at        timestamp   [not null, default: `now()`]
  metadata          jsonb

  indexes {
    task_id
    user_id
    status
    assigned_at
    (user_id, status, assigned_at)
  }
}

// ─── ANNOTATIONS ─────────────────────────────────────────────────────────────

Table annotations {
  id               uuid         [pk, default: `gen_random_uuid()`]
  task_id          uuid         [not null, ref: > tasks.id]
  assignment_id    uuid         [not null, ref: > assignments.id]
  user_id          uuid         [not null, ref: > users.id]
  annotation_data  jsonb        [not null, note: '{labels[], spans[], entities[], relationships[], attributes, freeText}']
  version          integer      [not null, default: 1]
  is_final         boolean      [not null, default: false]
  confidence_score decimal(3,2) [note: '0-1']
  time_spent       integer      [note: 'seconds']
  tool_version     varchar(50)
  submitted_at     timestamp
  created_at       timestamp    [not null, default: `now()`]
  updated_at       timestamp    [not null, default: `now()`]
  metadata         jsonb

  indexes {
    task_id
    user_id
    submitted_at
    is_final
    (task_id, version)
  }
}

// ─── ANNOTATION RESPONSES ─────────────────────────────────────────────────────

Table annotation_responses {
  id               uuid         [pk, default: `gen_random_uuid()`]
  task_id          uuid         [not null, ref: > tasks.id]
  annotation_id    uuid         [not null, ref: > annotations.id]
  assignment_id    uuid         [not null, ref: > assignments.id]
  question_id      varchar(255) [not null]
  question_text    text         [not null]
  question_type    varchar(50)  [not null, note: 'MULTI_SELECT | TEXT | SINGLE_SELECT | NUMBER | DATE']
  response         jsonb        [not null, note: '{value, selectedOptions[], textValue, numberValue, dateValue}']
  time_spent       integer      [note: 'seconds']
  confidence_score decimal(5,2) [note: '0-100']
  is_skipped       boolean      [not null, default: false]
  skip_reason      text
  created_at       timestamp    [not null, default: `now()`]
  updated_at       timestamp    [not null, default: `now()`]
  metadata         jsonb

  indexes {
    task_id
    annotation_id
    assignment_id
    question_id
  }
}

// ─── ANNOTATION VERSIONS ──────────────────────────────────────────────────────

Table annotation_versions {
  id               uuid    [pk, default: `gen_random_uuid()`]
  annotation_id    uuid    [not null, ref: > annotations.id]
  task_id          uuid    [not null, ref: > tasks.id]
  user_id          uuid    [not null, ref: > users.id]
  version          integer [not null]
  annotation_data  jsonb   [not null]
  change_reason    text
  created_at       timestamp [not null, default: `now()`]
  updated_at       timestamp [not null, default: `now()`]
  metadata         jsonb

  indexes {
    annotation_id
    task_id
    (annotation_id, version)
  }
}

// ─── REVIEW APPROVALS ─────────────────────────────────────────────────────────

Table review_approvals {
  id                 uuid        [pk, default: `gen_random_uuid()`]
  task_id            uuid        [not null, ref: > tasks.id]
  assignment_id      uuid        [not null, ref: > assignments.id]
  reviewer_id        uuid        [not null, ref: > users.id]
  review_level       integer     [not null, note: '1-5']
  status             varchar(25) [not null, note: 'PENDING | APPROVED | REJECTED | CHANGES_REQUESTED']
  comments           text
  feedback           jsonb       [note: '{issues[{questionId,issue,severity}], suggestions[], qualityScore}']
  reviewed_at        timestamp
  time_spent         integer     [note: 'seconds']
  requested_changes  jsonb       [note: 'Array<{field, currentValue, suggestedValue, reason}>']
  created_at         timestamp   [not null, default: `now()`]
  updated_at         timestamp   [not null, default: `now()`]
  metadata           jsonb

  indexes {
    task_id
    reviewer_id
    assignment_id
    review_level
    status
    (task_id, review_level, status)
  }
}

// ─── QUALITY CHECKS ──────────────────────────────────────────────────────────

Table quality_checks {
  id                       uuid         [pk, default: `gen_random_uuid()`]
  task_id                  uuid         [not null, ref: > tasks.id]
  annotation_id            uuid         [not null, ref: > annotations.id]
  reviewer_id              uuid         [ref: > users.id]
  check_type               varchar(20)  [not null, note: 'AUTOMATED | MANUAL | CONSENSUS | GOLD_STANDARD']
  status                   varchar(20)  [not null, note: 'PASS | FAIL | NEEDS_REVISION | DISPUTED']
  quality_score            decimal(5,2) [not null, note: '0-100']
  issues                   jsonb        [note: 'Array<{category, severity, description, location}>']
  feedback                 text
  corrected_annotation_id  uuid         [ref: > annotations.id]
  resolved_at              timestamp
  created_at               timestamp    [not null, default: `now()`]
  updated_at               timestamp    [not null, default: `now()`]
  metadata                 jsonb

  indexes {
    task_id
    annotation_id
    reviewer_id
    check_type
    status
  }
}

// ─── QUALITY RULES ───────────────────────────────────────────────────────────

Table quality_rules {
  id          uuid         [pk, default: `gen_random_uuid()`]
  project_id  uuid         [not null, ref: > projects.id]
  name        varchar(255) [not null]
  description text
  rule_type   varchar(100) [not null]
  conditions  jsonb        [not null]
  threshold   numeric
  severity    varchar(20)  [not null, note: 'LOW | MEDIUM | HIGH | CRITICAL']
  is_active   boolean      [not null, default: true]
  created_at  timestamp    [not null, default: `now()`]
  updated_at  timestamp    [not null, default: `now()`]
  metadata    jsonb

  indexes {
    project_id
    is_active
  }
}

// ─── GOLD TASKS ──────────────────────────────────────────────────────────────

Table gold_tasks {
  id               uuid    [pk, default: `gen_random_uuid()`]
  task_id          uuid    [unique, not null, ref: - tasks.id]
  project_id       uuid    [not null, ref: > projects.id]
  gold_annotation  jsonb   [not null, note: '{labels[], spans[], entities[], relationships[], attributes, freeText}']
  tolerance        jsonb   [note: '{boundaryIouThreshold, labelExactMatch, attributeMatch, scoreWeights}']
  created_by       uuid    [not null, ref: > users.id]
  is_active        boolean [not null, default: true]
  created_at       timestamp [not null, default: `now()`]
  updated_at       timestamp [not null, default: `now()`]
  metadata         jsonb

  indexes {
    task_id [unique]
    project_id
  }
}

// ─── QUEUES ──────────────────────────────────────────────────────────────────

Table queues {
  id               uuid         [pk, default: `gen_random_uuid()`]
  name             varchar(255) [not null]
  project_id       uuid         [not null, ref: > projects.id]
  queue_type       varchar(20)  [not null, note: 'ANNOTATION | REVIEW | VALIDATION | CONSENSUS']
  status           varchar(20)  [not null, note: 'ACTIVE | PAUSED | ARCHIVED']
  priority_rules   jsonb        [note: '{priorityField, sortOrder, filters[]}']
  assignment_rules jsonb        [note: '{autoAssign, capacityLimits, skillRequirements[], loadBalancing}']
  total_tasks      integer      [not null, default: 0]
  pending_tasks    integer      [not null, default: 0]
  created_at       timestamp    [not null, default: `now()`]
  updated_at       timestamp    [not null, default: `now()`]
  metadata         jsonb

  indexes {
    project_id
    queue_type
    status
  }
}

// ─── WORKFLOWS ───────────────────────────────────────────────────────────────

Table workflows {
  id                   uuid         [pk, default: `gen_random_uuid()`]
  project_id           uuid         [ref: > projects.id]
  name                 varchar(255) [not null]
  description          text
  version              integer      [not null, default: 1]
  xstate_definition    jsonb        [not null, note: '{id, initial, context, states, guards, actions, services, delays}']
  state_schema         jsonb        [note: '{states, context}']
  event_schema         jsonb        [note: 'Array<{eventType, payloadSchema, description}>']
  visualization_config jsonb        [note: '{layout, nodePositions, styling}']
  status               varchar(20)  [not null, note: 'DRAFT | ACTIVE | INACTIVE | DEPRECATED']
  is_template          boolean      [not null, default: false]
  parent_workflow_id   uuid         [ref: > workflows.id]
  created_by           uuid         [not null, ref: > users.id]
  created_at           timestamp    [not null, default: `now()`]
  updated_at           timestamp    [not null, default: `now()`]
  metadata             jsonb

  indexes {
    project_id
    status
    version
    is_template
  }
}

// ─── WORKFLOW INSTANCES ───────────────────────────────────────────────────────

Table workflow_instances {
  id                 uuid         [pk, default: `gen_random_uuid()`]
  workflow_id        uuid         [not null, ref: > workflows.id]
  batch_id           uuid         [ref: > batches.id]
  name               varchar(255) [not null]
  actor_state        jsonb        [not null, note: '{value, context, children, history, done, tags[]}']
  parent_instance_id uuid         [ref: > workflow_instances.id]
  actor_type         varchar(20)  [not null, note: 'ROOT | CHILD | INVOKED']
  actor_ref_id       varchar(255)
  parallel_states    jsonb        [note: '{regions}']
  snapshot           jsonb
  checkpoint_at      timestamp
  status             varchar(20)  [not null, note: 'RUNNING | PAUSED | COMPLETED | FAILED | STOPPED']
  started_at         timestamp
  completed_at       timestamp
  error              jsonb
  created_at         timestamp    [not null, default: `now()`]
  updated_at         timestamp    [not null, default: `now()`]
  metadata           jsonb

  indexes {
    workflow_id
    batch_id
    status
    actor_type
    parent_instance_id
    (batch_id, status)
  }
}

// ─── STATE TRANSITIONS ────────────────────────────────────────────────────────

Table state_transitions {
  id                uuid        [pk, default: `gen_random_uuid()`]
  entity_type       varchar(25) [not null, note: 'TASK | BATCH | ASSIGNMENT | WORKFLOW_INSTANCE']
  entity_id         uuid        [not null]
  workflow_id       uuid        [not null, ref: > workflows.id]
  event             jsonb       [not null, note: '{type, payload, timestamp, origin}']
  from_state        jsonb       [not null, note: '{value, context, tags[]}']
  to_state          jsonb       [not null, note: '{value, context, tags[]}']
  transition_type   varchar(20) [not null, note: 'EXTERNAL | INTERNAL | DELAYED | GUARDED | ALWAYS']
  guards_evaluated  jsonb       [note: 'Array<{guardName, result, condition}>']
  actions_executed  jsonb       [note: 'Array<{actionName, actionType, executionTime, result}>']
  user_id           uuid        [ref: > users.id]
  triggered_by      varchar(20) [note: 'USER_ACTION | SYSTEM | TIMER | WEBHOOK | SERVICE']
  duration          integer     [note: 'milliseconds']
  is_automatic      boolean     [not null, default: false]
  error             jsonb
  created_at        timestamp   [not null, default: `now()`]
  updated_at        timestamp   [not null, default: `now()`]
  metadata          jsonb

  indexes {
    entity_type
    entity_id
    workflow_id
    created_at
    user_id
    (entity_type, entity_id, created_at)
  }
}

// ─── EXPORTS ─────────────────────────────────────────────────────────────────

Table exports {
  id               uuid         [pk, default: `gen_random_uuid()`]
  batch_id         uuid         [not null, ref: > batches.id]
  project_id       uuid         [not null, ref: > projects.id]
  export_type      varchar(20)  [not null, note: 'FULL | INCREMENTAL | FILTERED']
  format           varchar(20)  [not null, note: 'JSON | JSONL | CSV | COCO | PASCAL_VOC | CUSTOM']
  status           varchar(20)  [not null, note: 'PENDING | PROCESSING | COMPLETED | FAILED']
  file_url         text
  file_size        bigint       [note: 'bytes']
  record_count     integer
  filter_criteria  jsonb
  configuration    jsonb        [note: '{includeMetadata, includeQualityMetrics, anonymize, compression}']
  requested_by     uuid         [not null, ref: > users.id]
  completed_at     timestamp
  expires_at       timestamp
  error_message    text
  created_at       timestamp    [not null, default: `now()`]
  updated_at       timestamp    [not null, default: `now()`]
  metadata         jsonb

  indexes {
    batch_id
    project_id
    status
    created_at
  }
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

Table audit_logs {
  id          uuid        [pk, default: `gen_random_uuid()`]
  entity_type varchar(50) [not null]
  entity_id   uuid        [not null]
  action      varchar(20) [not null, note: 'CREATE | READ | UPDATE | DELETE | ASSIGN | SUBMIT | APPROVE | REJECT | EXPORT']
  user_id     uuid        [not null, ref: > users.id]
  timestamp   timestamp   [not null]
  ip_address  varchar(45)
  user_agent  text
  changes     jsonb       [note: '{before, after}']
  created_at  timestamp   [not null, default: `now()`]
  updated_at  timestamp   [not null, default: `now()`]
  metadata    jsonb

  indexes {
    entity_type
    entity_id
    user_id
    timestamp
    action
    (entity_type, entity_id, timestamp)
  }
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

Table notifications {
  id         uuid        [pk, default: `gen_random_uuid()`]
  user_id    uuid        [not null, ref: > users.id]
  type       varchar(30) [not null, note: 'TASK_ASSIGNED | TASK_EXPIRED | FEEDBACK_RECEIVED | BATCH_COMPLETED | SYSTEM_ALERT']
  priority   varchar(10) [not null, note: 'LOW | MEDIUM | HIGH | URGENT']
  title      varchar(255) [not null]
  message    text        [not null]
  link       text
  is_read    boolean     [not null, default: false]
  read_at    timestamp
  expires_at timestamp
  created_at timestamp   [not null, default: `now()`]
  updated_at timestamp   [not null, default: `now()`]
  metadata   jsonb

  indexes {
    user_id
    is_read
    created_at
  }
}

// ─── COMMENTS ────────────────────────────────────────────────────────────────

Table comments {
  id                uuid    [pk, default: `gen_random_uuid()`]
  task_id           uuid    [not null, ref: > tasks.id]
  user_id           uuid    [not null, ref: > users.id]
  parent_comment_id uuid    [ref: > comments.id]
  content           text    [not null]
  attachments       jsonb
  is_resolved       boolean [not null, default: false]
  resolved_at       timestamp
  resolved_by       uuid    [ref: > users.id]
  created_at        timestamp [not null, default: `now()`]
  updated_at        timestamp [not null, default: `now()`]
  metadata          jsonb

  indexes {
    task_id
    user_id
    parent_comment_id
  }
}

// ─── TEMPLATES ───────────────────────────────────────────────────────────────

Table templates {
  id            uuid         [pk, default: `gen_random_uuid()`]
  name          varchar(255) [not null]
  category      varchar(100) [not null]
  template_type varchar(30)  [not null, note: 'ANNOTATION_SCHEMA | UI_CONFIG | QUALITY_RULES | WORKFLOW']
  content       jsonb        [not null]
  is_public     boolean      [not null, default: false]
  created_by    uuid         [not null, ref: > users.id]
  usage_count   integer      [not null, default: 0]
  created_at    timestamp    [not null, default: `now()`]
  updated_at    timestamp    [not null, default: `now()`]
  metadata      jsonb

  indexes {
    template_type
    is_public
    created_by
  }
}

// ─── PLUGIN SECRETS ──────────────────────────────────────────────────────────

Table plugin_secrets {
  id          uuid         [pk, default: `gen_random_uuid()`]
  project_id  uuid         [not null, ref: > projects.id]
  name        varchar(255) [not null]
  value       text         [not null, note: 'encrypted at rest']
  description varchar(255)
  created_by  uuid         [ref: > users.id]
  created_at  timestamp    [not null, default: `now()`]
  updated_at  timestamp    [not null, default: `now()`]
  metadata    jsonb

  indexes {
    (project_id, name) [unique]
  }
}

// ─── PLUGIN EXECUTION LOGS ────────────────────────────────────────────────────

Table plugin_execution_logs {
  id           uuid        [pk, default: `gen_random_uuid()`]
  project_id   uuid        [not null, ref: > projects.id]
  task_id      uuid        [ref: > tasks.id]
  plugin_id    varchar(255) [not null]
  plugin_name  varchar(255) [not null]
  trigger      varchar(20) [not null, note: 'ON_BLUR | ON_SUBMIT']
  result       varchar(10) [not null, note: 'PASS | WARN | FAIL']
  duration_ms  integer     [not null]
  error        text
  executed_at  timestamp   [not null]
  created_at   timestamp   [not null, default: `now()`]
  updated_at   timestamp   [not null, default: `now()`]
  metadata     jsonb

  indexes {
    project_id
    task_id
    result
    executed_at
  }
}

// ─── UI CONFIGURATIONS ────────────────────────────────────────────────────────
// Versioned UI builder configs per project (served by Project Management service)

Table ui_configurations {
  id         uuid         [pk, default: `gen_random_uuid()`]
  project_id uuid         [not null, ref: > projects.id]
  version    integer      [not null, default: 1]
  config     jsonb        [not null, note: 'UI builder widget layout and configuration']
  is_active  boolean      [not null, default: false]
  created_by uuid         [ref: > users.id]
  created_at timestamp    [not null, default: `now()`]
  updated_at timestamp    [not null, default: `now()`]
  metadata   jsonb

  indexes {
    project_id
    (project_id, version) [unique]
    is_active
  }
}
