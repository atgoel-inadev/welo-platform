{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/workflow-engine/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/workflow-engine/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/workflow-engine",
  "projects": {
    "workflow-engine": {
      "type": "application",
      "root": "apps/workflow-engine",
      "entryFile": "main",
      "sourceRoot": "apps/workflow-engine/src",
      "compilerOptions": {
        "tsConfigPath": "apps/workflow-engine/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json",
        "assets": [
          {
            "include": "auth/mock-users.json",
            "outDir": "dist/apps/auth-service"
          }
        ]
      }
    },
    "task-management": {
      "type": "application",
      "root": "apps/task-management",
      "entryFile": "main",
      "sourceRoot": "apps/task-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/task-management/tsconfig.app.json"
      }
    },
    "project-management": {
      "type": "application",
      "root": "apps/project-management",
      "entryFile": "main",
      "sourceRoot": "apps/project-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/project-management/tsconfig.app.json"
      }
    },
    "annotation-qa-service": {
      "type": "application",
      "root": "apps/annotation-qa-service",
      "entryFile": "main",
      "sourceRoot": "apps/annotation-qa-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/annotation-qa-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "infrastructure": {
      "type": "library",
      "root": "libs/infrastructure",
      "entryFile": "index",
      "sourceRoot": "libs/infrastructure/src",
      "compilerOptions": {
        "tsConfigPath": "libs/infrastructure/tsconfig.lib.json"
      }
    },
    "file-storage-service": {
      "type": "application",
      "root": "apps/file-storage-service",
      "entryFile": "main",
      "sourceRoot": "apps/file-storage-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/file-storage-service/tsconfig.app.json"
      }
    },
    "export-service": {
      "type": "application",
      "root": "apps/export-service",
      "entryFile": "main",
      "sourceRoot": "apps/export-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/export-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "analytics-service": {
      "type": "application",
      "root": "apps/analytics-service",
      "entryFile": "main",
      "sourceRoot": "apps/analytics-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/analytics-service/tsconfig.app.json"
      }
    },
    "audit-service": {
      "type": "application",
      "root": "apps/audit-service",
      "entryFile": "main",
      "sourceRoot": "apps/audit-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/audit-service/tsconfig.app.json"
      }
    }
  }
}
